@page "/documents/upload"
@attribute [Authorize]
@using MudBlazor
@using ErpShowroom.Client.Services
@inject IApiClient ApiClient
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" GutterBottom="true">Upload Documents</MudText>

<MudPaper Class="pa-8">
    <MudFileUpload T="IBrowserFile" FilesChanged="UploadFile" Accept="image/*,application/pdf" />

    @if (isUploading)
    {
        <MudProgressLinear Color="MudBlazor.Color.Info" Value="@uploadProgress" Class="mt-4" />
    }

    @if (ocrData != null)
    {
        <MudText Typo="Typo.h6" Class="mt-8">Extracted OCR Data</MudText>
        <MudCard Elevation="2" Class="pa-4 mt-2">
            <MudText><b>NID Number:</b> @ocrData.NidNumber</MudText>
            <MudText><b>Name:</b> @ocrData.Name</MudText>
            <MudText><b>Confidence:</b> @ocrData.Confidence.ToString("P1")</MudText>
        </MudCard>
    }
</MudPaper>

@code {
    bool isUploading;
    int uploadProgress;
    OcrDataDto? ocrData;

    async Task UploadFile(IBrowserFile file)
    {
        isUploading = true;
        uploadProgress = 10;

        try
        {
            var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.Name);

            uploadProgress = 40;

            var uploadResponse = await ApiClient.PostContentAsync("documents/upload", content);
            if (!uploadResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Upload failed", Severity.Error);
                return;
            }

            uploadProgress = 70;
            var docId = await uploadResponse.Content.ReadFromJsonAsync<long>();
            Snackbar.Add("File uploaded, starting OCR processing...", Severity.Info);

            // PostAsync<OcrDataDto> returns the DTO directly — no .IsSuccessStatusCode needed
            ocrData = await ApiClient.PostAsync<OcrDataDto>($"documents/ocr/{docId}", new { });
            if (ocrData != null)
            {
                Snackbar.Add("OCR completed successfully", Severity.Success);
            }
            else
            {
                Snackbar.Add("OCR processing failed", Severity.Error);
            }

            uploadProgress = 100;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isUploading = false;
        }
    }

    public class OcrDataDto { public string NidNumber { get; set; } = ""; public string Name { get; set; } = ""; public decimal Confidence { get; set; } }
}
