@using MudBlazor
@using ErpShowroom.Client.Services
@inject ISystemService SystemService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Class="mr-3 mb-n1" />
            Reset Password for @UserName
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudTextField T="string" Label="New Password" @bind-Value="NewPassword"
                          InputType="InputType.Password"
                          Required="true" RequiredError="Password is required"
                          Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField T="string" Label="Confirm Password" @bind-Value="ConfirmPassword"
                          InputType="InputType.Password"
                          Required="true" RequiredError="Confirmation is required"
                          Validation="@(new Func<string, string?>(ValidateConfirm))"
                          Variant="Variant.Outlined" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Warning" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Reset Password
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string UserName { get; set; } = "";
    [Parameter] public long UserId { get; set; }

    private string NewPassword = "";
    private string ConfirmPassword = "";
    private bool _isValid;
    private bool _saving;
    private MudForm _form = null!;

    private string? ValidateConfirm(string confirm)
    {
        if (confirm != NewPassword) return "Passwords do not match";
        return null;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            var success = await SystemService.ResetPasswordAsync(UserId, NewPassword);
            if (success)
            {
                Snackbar.Add("Password reset successfully", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else Snackbar.Add("Failed to reset password", Severity.Error);
        }
        finally { _saving = false; }
    }
}
