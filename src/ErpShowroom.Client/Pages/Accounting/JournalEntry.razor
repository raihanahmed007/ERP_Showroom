@page "/accounting/journal-entry"
@attribute [Authorize]
@using MudBlazor
@using ErpShowroom.Client.Services
@inject IApiClient ApiClient
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" GutterBottom="true">Journal Entry</MudText>

<MudPaper Class="pa-8" Elevation="3">
    <MudForm @ref="form">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="Entry Date" @bind-Date="entry.Date" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Reference" @bind-Value="entry.Description" />
            </MudItem>
        </MudGrid>

        <MudTable Items="@entry.Lines" Hover="true" Dense="true" Elevation="0" Class="mt-6">
            <HeaderContent>
                <MudTh>Account</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Debit</MudTh>
                <MudTh>Credit</MudTh>
                <MudTh Style="width: 60px;">Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudSelect T="long" @bind-Value="context.AccountId" Required="true" Dense="true" Margin="Margin.Dense">
                        @foreach (var acc in accounts)
                        {
                            <MudSelectItem Value="@acc.Id">@acc.Code – @acc.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudTd>
                <MudTd>
                    <MudTextField T="string" @bind-Value="context.Description" Dense="true" Margin="Margin.Dense" />
                </MudTd>
                <MudTd>
                    <MudNumericField T="decimal" @bind-Value="context.Debit" Min="0" Format="N2" HideSpinButtons="true" Dense="true" Margin="Margin.Dense" />
                </MudTd>
                <MudTd>
                    <MudNumericField T="decimal" @bind-Value="context.Credit" Min="0" Format="N2" HideSpinButtons="true" Dense="true" Margin="Margin.Dense" />
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="MudBlazor.Color.Error" Size="Size.Small" OnClick="@(() => RemoveLine(context))" Disabled="@(entry.Lines.Count <= 2)" />
                </MudTd>
            </RowTemplate>
            <FooterContent>
                <MudTd colspan="2"><MudText Align="Align.Right"><strong>Totals:</strong></MudText></MudTd>
                <MudTd><MudText Color="@(IsBalanced ? MudBlazor.Color.Success : MudBlazor.Color.Error)"><strong>@TotalDebit.ToString("N2")</strong></MudText></MudTd>
                <MudTd><MudText Color="@(IsBalanced ? MudBlazor.Color.Success : MudBlazor.Color.Error)"><strong>@TotalCredit.ToString("N2")</strong></MudText></MudTd>
                <MudTd></MudTd>
            </FooterContent>
        </MudTable>

        <div class="d-flex align-center justify-space-between mt-4">
            <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="AddLine" Color="MudBlazor.Color.Info" Variant="Variant.Text">Add Line</MudButton>
            <div class="d-flex align-center gap-4">
                @if (!IsBalanced && (TotalDebit > 0 || TotalCredit > 0))
                {
                    <MudChip T="string" Color="MudBlazor.Color.Error" Size="Size.Small">
                        Difference: @Math.Abs(TotalDebit - TotalCredit).ToString("N2")
                    </MudChip>
                }
                <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="SubmitEntry" Disabled="@(!IsBalanced || isSubmitting)">
                    @if (isSubmitting)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                    }
                    Submit Journal Entry
                </MudButton>
            </div>
        </div>
    </MudForm>
</MudPaper>

@code {
    MudForm form = default!;
    bool isSubmitting;
    JournalEntryDto entry = new() { Date = DateTime.Today, Lines = new List<JournalLineDto> { new(), new() } };
    List<AccountDto> accounts = new();

    decimal TotalDebit => entry.Lines.Sum(l => l.Debit);
    decimal TotalCredit => entry.Lines.Sum(l => l.Credit);
    bool IsBalanced => TotalDebit > 0 && TotalDebit == TotalCredit;

    protected override async Task OnInitializedAsync()
    {
        accounts = await ApiClient.GetAsync<List<AccountDto>>("accounting/accounts") ?? new();
    }

    void AddLine() => entry.Lines.Add(new());
    void RemoveLine(JournalLineDto line)
    {
        if (entry.Lines.Count > 2) entry.Lines.Remove(line);
    }

    async Task SubmitEntry()
    {
        if (!IsBalanced) return;
        isSubmitting = true;
        try
        {
            var success = await ApiClient.PostAsync<object>("accounting/journal-entries", entry);
            if (success != null)
            {
                Snackbar.Add("Journal entry posted successfully!", Severity.Success);
                entry = new() { Date = DateTime.Today, Lines = new List<JournalLineDto> { new(), new() } };
            }
            else
            {
                Snackbar.Add("Failed to post journal entry", Severity.Error);
            }
        }
        finally { isSubmitting = false; }
    }

    public class JournalEntryDto { public DateTime? Date { get; set; } public string Description { get; set; } = ""; public List<JournalLineDto> Lines { get; set; } = new(); }
    public class JournalLineDto { public long AccountId { get; set; } public string Description { get; set; } = ""; public decimal Debit { get; set; } public decimal Credit { get; set; } }
    public class AccountDto { public long Id { get; set; } public string Code { get; set; } = ""; public string Name { get; set; } = ""; }
}
