@page "/accounting"
@attribute [Authorize]
@using MudBlazor
@using ErpShowroom.Client.Services
@inject IApiClient ApiClient
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" GutterBottom="true">Journal Entry</MudText>

<MudPaper Class="pa-8">
    <MudGrid>
        <MudItem xs="12">
            <MudTable Items="@lines" Hover="true" Breakpoint="Breakpoint.Sm">
                <HeaderContent>
                    <MudTh>Account</MudTh>
                    <MudTh>Debit</MudTh>
                    <MudTh>Credit</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudSelect T="long" @bind-Value="context.AccountId" Label="Select Account">
                            @foreach (var acc in accounts)
                            {
                                <MudSelectItem Value="@acc.Id">@acc.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd><MudNumericField T="decimal" @bind-Value="context.Debit" Format="N2" /></MudTd>
                    <MudTd><MudNumericField T="decimal" @bind-Value="context.Credit" Format="N2" /></MudTd>
                    <MudTd><MudTextField @bind-Value="context.Description" /></MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="MudBlazor.Color.Error" OnClick="@(() => RemoveLine(context))" />
                    </MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd>Total:</MudTd>
                    <MudTd>@TotalDebit.ToString("N2")</MudTd>
                    <MudTd>@TotalCredit.ToString("N2")</MudTd>
                    <MudTd></MudTd>
                    <MudTd></MudTd>
                </FooterContent>
            </MudTable>
            <MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="AddLine" Color="MudBlazor.Color.Info">Add Line</MudButton>
        </MudItem>
        <MudItem xs="12" Class="mt-8">
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" OnClick="SubmitJournal" Disabled="@(!IsBalanced)">Submit Journal Entry</MudButton>
            @if (!IsBalanced)
            {
                <MudAlert Severity="Severity.Warning" Class="mt-4">Total Debit must equal Total Credit.</MudAlert>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

<MudText Typo="Typo.h4" Class="mt-12" GutterBottom="true">Trial Balance</MudText>
<MudPaper Class="pa-8">
    <MudGrid>
        <MudItem xs="6">
            <MudDatePicker Label="Report Month" @bind-Date="trialBalanceDate" OpenTo="OpenTo.Year" FixDay="1" TransformOrigin="Origin.CenterCenter" />
        </MudItem>
        <MudItem xs="6">
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Info" OnClick="LoadTrialBalance" Class="mt-4">Generate Report</MudButton>
        </MudItem>
        <MudItem xs="12">
            <MudTable Items="@trialBalanceEntries" Hover="true" Loading="@loadingTrialBalance">
                <HeaderContent>
                    <MudTh>Account Code</MudTh>
                    <MudTh>Account Name</MudTh>
                    <MudTh>Debit</MudTh>
                    <MudTh>Credit</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Code</MudTd>
                    <MudTd>@context.Name</MudTd>
                    <MudTd>@context.Debit.ToString("N2")</MudTd>
                    <MudTd>@context.Credit.ToString("N2")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    List<JournalLineRequestDto> lines = new() { new(), new() };
    List<AccountDto> accounts = new();
    List<TrialBalanceEntryDto> trialBalanceEntries = new();
    DateTime? trialBalanceDate = DateTime.Today;
    bool loadingTrialBalance;

    decimal TotalDebit => lines.Sum(l => l.Debit);
    decimal TotalCredit => lines.Sum(l => l.Credit);
    bool IsBalanced => TotalDebit > 0 && TotalDebit == TotalCredit;

    protected override async Task OnInitializedAsync()
    {
        accounts = await ApiClient.GetAsync<List<AccountDto>>("accounting/accounts") ?? new();
    }

    void AddLine() => lines.Add(new());
    void RemoveLine(JournalLineRequestDto line) => lines.Remove(line);

    async Task SubmitJournal()
    {
        var success = await ApiClient.PostAsync<object>("accounting/journal-entries", new { Lines = lines });
        if (success != null)
        {
            Snackbar.Add("Journal Entry submitted", Severity.Success);
            lines = new() { new(), new() };
        }
        else Snackbar.Add("Failed to submit Journal Entry", Severity.Error);
    }

    async Task LoadTrialBalance()
    {
        if (trialBalanceDate == null) return;
        loadingTrialBalance = true;
        trialBalanceEntries = await ApiClient.GetAsync<List<TrialBalanceEntryDto>>($"accounting/trial-balance?periodId={trialBalanceDate.Value:yyyyMM}") ?? new();
        loadingTrialBalance = false;
    }

    public class AccountDto { public long Id { get; set; } public string Name { get; set; } = ""; }
    public class JournalLineRequestDto { public long AccountId { get; set; } public decimal Debit { get; set; } public decimal Credit { get; set; } public string Description { get; set; } = ""; }
    public class TrialBalanceEntryDto { public string Code { get; set; } = ""; public string Name { get; set; } = ""; public decimal Debit { get; set; } public decimal Credit { get; set; } }
}
