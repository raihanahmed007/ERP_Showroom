@inherits LayoutComponentBase
@using MudBlazor
@using ErpShowroom.Client.Services
@using System.Security.Claims
@implements IDisposable

<MudThemeProvider Theme="@ThemeService.MudTheme" IsDarkMode="@(_isDarkMode)" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="border-b mud-border-lines-default">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <div class="logo-wrapper ml-2">
            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Class="ml-2 font-bold tracking-tighter d-none d-sm-inline">
                Himu Motors ERP
            </MudText>
        </div>
        <MudSpacer />
        
        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem OnClick="@(async () => await SetTheme(ThemeService.AppTheme.Normal))">Normal Theme</MudMenuItem>
            <MudMenuItem OnClick="@(async () => await SetTheme(ThemeService.AppTheme.Dark))">Dark Theme</MudMenuItem>
            <MudMenuItem OnClick="@(async () => await SetTheme(ThemeService.AppTheme.Purple))">Purple Theme</MudMenuItem>
        </MudMenu>

        <AuthorizeView>
            <Authorized>
                <div class="d-flex align-center ml-4">
                    <MudBadge Dot="true" Color="Color.Success" Overlap="true" Bordered="true">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">@((context.User.Identity?.Name?.Length > 0 ? context.User.Identity.Name.Substring(0, 1) : "U").ToUpper())</MudAvatar>
                    </MudBadge>
                    <div class="ml-3 d-none d-md-flex flex-column">
                        <MudText Typo="Typo.caption" Class="font-bold">@context.User.Identity?.Name</MudText>
                        <MudText Typo="Typo.caption" Style="font-size: 0.65rem">@string.Join(", ", context.User.Claims.Where(c => c.Type == "roles" || c.Type == ClaimTypes.Role).Select(c => c.Value).Distinct())</MudText>
                    </div>
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="Logout" Class="ml-2" />
                </div>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Href="/login">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Class="border-r mud-border-lines-default">
        <div class="drawer-header px-4 py-6 text-center">
             <MudAvatar Color="Color.Primary" Style="height:60px; width:60px;">HM</MudAvatar>
             <MudText Typo="Typo.subtitle1" Class="mt-2 font-bold">Workspace</MudText>
        </div>
        <NavMenu />
    </MudDrawer>
    <MudMainContent Class="mud-background-gray-50">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;
    bool _isDarkMode = false;

    [Inject] IApiClient ApiClient { get; set; } = default!;
    [Inject] ThemeService ThemeService { get; set; } = default!;

    [Inject] IJSRuntime JSRuntime { get; set; } = default!;

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
        UpdateDarkMode();
    }

    private void UpdateDarkMode()
    {
        _isDarkMode = ThemeService.CurrentTheme == ThemeService.AppTheme.Dark;
    }

    private async Task SetTheme(ThemeService.AppTheme theme)
    {
        ThemeService.SetTheme(theme);
        UpdateDarkMode();
        
        if (theme == ThemeService.AppTheme.Purple)
            await JSRuntime.InvokeVoidAsync("document.documentElement.classList.add", "purple-theme");
        else
            await JSRuntime.InvokeVoidAsync("document.documentElement.classList.remove", "purple-theme");
    }

    void DrawerToggle() => _drawerOpen = !_drawerOpen;
    async Task Logout() => await ApiClient.LogoutAsync();

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}
